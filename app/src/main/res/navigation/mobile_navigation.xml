<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.istts.finalproject.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/navigation_mood_tracker"
        android:name="com.istts.finalproject.ui.mood.MoodTrackerFragment"
        android:label="Cek Mood"
        tools:layout="@layout/fragment_mood_tracker" />

    <fragment
        android:id="@+id/navigation_mood_history"
        android:name="com.istts.finalproject.ui.mood.MoodHistoryFragment"
        android:label="Riwayat Mood"
        tools:layout="@layout/fragment_mood_history" />

    <fragment
        android:id="@+id/navigation_articles"
        android:name="com.istts.finalproject.ui.article.ArticleListFragment"
        android:label="Artikel"
        tools:layout="@layout/fragment_article_list" />

    <fragment
        android:id="@+id/navigation_emergency"
        android:name="com.istts.finalproject.ui.emergency.EmergencyContactFragment"
        android:label="Bantuan Darurat"
        tools:layout="@layout/fragment_emergency_contact" />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.istts.finalproject.ui.profile.ProfileFragment"
        android:label="Profil"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profile_to_edit_profile"
            app:destination="@id/editProfileFragment" />
        <action
            android:id="@+id/action_profile_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/navigation_profile"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.istts.finalproject.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/navigation_dashboard"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.istts.finalproject.ui.auth.RegisterFragment"
        android:label="Daftar"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/articleDetailFragment"
        android:name="com.istts.finalproject.ui.article.ArticleDetailFragment"
        android:label="Detail Artikel"
        tools:layout="@layout/fragment_article_detail">
        <argument
            android:name="articleId"
            app:argType="integer" />
        <argument
            android:name="articleTitle"
            app:argType="string" />
        <argument
            android:name="articleCategory"
            app:argType="string" />
        <argument
            android:name="articleContent"
            app:argType="string" />
        <argument
            android:name="articleDate"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.istts.finalproject.ui.profile.EditProfileFragment"
        android:label="Edit Profil"
        tools:layout="@layout/fragment_edit_profile" />

    <action
        android:id="@+id/action_articleList_to_articleDetail"
        app:destination="@id/articleDetailFragment" />

</navigation>